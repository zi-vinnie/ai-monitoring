# Path to the shared SQLite metadata DB the `server` component writes.
# Relative paths resolve against this .env file's directory; the default points
# at the sibling server component.
DB_PATH=../server/data/metadata.sqlite3

# --- Ollama (used by classify-screenshots) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=minicpm-v4.6
# Per-image request timeout in seconds (vision models can be slow on CPU).
OLLAMA_TIMEOUT=120
# Downscale each screenshot to this longest edge (px) before sending. Keeps big
# captures (e.g. 3200x2000) under a small vision model's context window and
# speeds up inference. 0 = send full resolution.
OLLAMA_IMAGE_MAX_EDGE=1280

# --- Reporting (used by send-report) ---
# Minutes each screenshot stands in for — set to your poll interval so the
# time estimates are accurate.
POLL_INTERVAL_MINUTES=5
# IANA timezone that defines "a day" for both jobs. Leave blank to use the
# server's local timezone.
REPORT_TZ=Europe/London

# --- Email delivery (SMTP; used by send-report) ---
# Example shows Gmail with an app password (see README "Setting up email").
# Any SMTP provider works.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Port 587 upgrades to TLS via STARTTLS (the default). For a provider that
# only offers implicit TLS on port 465, set SMTP_PORT=465 and SMTP_SSL=true.
SMTP_STARTTLS=true
SMTP_SSL=false
SMTP_USER=you@gmail.com
# For Gmail this must be a 16-character "app password", NOT your normal
# password — see the README. Spaces in it are fine.
SMTP_PASSWORD=your-app-password
EMAIL_FROM=you@gmail.com
# Comma-separated list of recipients.
EMAIL_TO=parent1@example.com,parent2@example.com
