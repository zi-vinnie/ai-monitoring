# Path to the shared SQLite metadata DB the `server` component writes.
# Relative paths resolve against this .env file's directory; the default points
# at the sibling server component.
DB_PATH=../server/data/metadata.sqlite3

# --- Ollama (used by classify-screenshots) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision
# Per-image request timeout in seconds (vision models can be slow on CPU).
OLLAMA_TIMEOUT=120

# --- Reporting (used by send-report) ---
# Minutes each screenshot stands in for — set to your poll interval so the
# time estimates are accurate.
POLL_INTERVAL_MINUTES=10
# IANA timezone that defines "a day" for both jobs. Leave blank to use the
# server's local timezone.
REPORT_TZ=Europe/London

# --- Email delivery (SMTP; used by send-report) ---
# Example shows Gmail with an app password. Any SMTP provider works.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=you@gmail.com
# Comma-separated list of recipients.
EMAIL_TO=parent1@example.com,parent2@example.com
